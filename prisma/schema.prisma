// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Shop configuration for widget display and settings
model ShopConfig {
  id   String @id @default(cuid())
  shop String @unique

  // General
  defaultBlog String  @default("News & Articles")
  language    String  @default("English")
  market      String  @default("United States")
  appStatus   Boolean @default(true)

  // Shoppable blog display
  productCardLayout    String  @default("Standard")
  cardPosition         String  @default("After paragraph")
  buttonText           String  @default("View product")
  showPrice            Boolean @default(true)
  showVariantSelector  Boolean @default(true)
  openInNewTab         Boolean @default(true)
  imageAspectRatio     String  @default("Square")
  imageFit             String  @default("Cover")
  cardDensity          String  @default("Comfortable")
  gridColumns          Int     @default(3)
  textAlignment        String  @default("Left")
  buttonStyle          String  @default("Solid")
  shadowStyle          String  @default("Soft")
  showCarouselArrows   Boolean @default(true)
  showCarouselDots     Boolean @default(true)
  carouselItemsVisible Int     @default(4)

  // SEO rules
  metaTitleTemplate       String  @default("{{title}} - {{blog}} | {{store}}")
  metaDescriptionTemplate String  @default("{{excerpt}}")
  urlHandleRules          String  @default("Use post title")
  canonicalRules          String  @default("Use default canonical (self)")
  addBlogSchema           Boolean @default(true)
  addProductSchema        Boolean @default(true)

  // Tracking & attribution
  attributionWindow        String  @default("7 days")
  utmRules                 String  @default("Auto-append to product links")
  enableConversionTracking Boolean @default(true)

  // AI writing rules
  brandTone               String  @default("Professional")
  defaultContentStructure String  @default("Introduction, H2 sections, Conclusion")
  autoGenerateAltText     Boolean @default(true)
  requireApproval         Boolean @default(true)
  forbiddenWords          String  @default("")
  seoAutoScanEnabled      Boolean @default(false)

  // Legacy fields
  widgetStyle   String  @default("carousel")
  primaryColor  String  @default("#6366f1")
  showRating    Boolean @default(true)
  showAddToCart Boolean @default(true)
  seoAutoSchema Boolean @default(true)
  maxProducts   Int     @default(6)
  borderRadius  String  @default("8px")
  customCss     String?

  // Content navigation
  breadcrumbsEnabled          Boolean @default(true)
  breadcrumbsStyle            String  @default("minimal")
  breadcrumbsShowHome         Boolean @default(true)
  breadcrumbsHomeLabel        String  @default("Home")
  breadcrumbsShowBlog         Boolean @default(true)
  breadcrumbsCurrentClickable Boolean @default(false)
  breadcrumbsSeparator        String  @default("/")
  tocEnabled                  Boolean @default(true)
  tocAutoInsertEnabled        Boolean @default(true)
  tocAutoInsertPosition       String  @default("after-title")
  tocTitle                    String  @default("Table of contents")
  tocLevels                   String  @default("h2,h3")
  tocStyle                    String  @default("boxed")
  tocLayout                   String  @default("vertical")
  tocNumbering                Boolean @default(false)
  tocSmoothScroll             Boolean @default(true)
  tocMobileCollapsed          Boolean @default(true)
  tocStickyOffset             Int     @default(96)
  contentNavPrimaryColor      String  @default("#6366f1")
  contentNavCustomCss         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Mapping: Article <-> Product
model ArticleProduct {
  id            String   @id @default(cuid())
  shop          String
  articleId     String
  articleTitle  String
  articleHandle String
  blogId        String
  productId     String
  productTitle  String
  productHandle String
  productImage  String   @default("")
  productPrice  String   @default("0")
  blockId       String   @default("default")
  position      Int      @default(0)
  displayStyle  String   @default("card")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([shop, articleId, blockId, productId])
  @@index([shop])
  @@index([articleId])
  @@index([articleId, blockId])
}

// SEO metadata for articles
model ArticleSEO {
  id              String    @id @default(cuid())
  shop            String
  articleId       String
  articleTitle    String    @default("")
  seoScore        Int       @default(0)
  metaTitle       String?
  metaDescription String?
  focusKeyword    String?
  schemaGenerated Boolean   @default(false)
  lastAnalyzedAt  DateTime?
  issues          String?
  articleHandle   String    @default("")
  blogTitle       String    @default("")
  blogHandle      String    @default("")
  imageUrl        String    @default("")
  imageAlt        String    @default("")
  sourceUpdatedAt DateTime?
  publishedAt     DateTime?
  contentHash     String?
  auditVersion    Int       @default(1)
  baseSeoScore    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([shop, articleId])
  @@index([shop])
  @@index([shop, sourceUpdatedAt])
}

model ResourceSEO {
  id              String    @id @default(cuid())
  shop            String
  resourceType    String
  resourceId      String
  title           String    @default("")
  handle          String    @default("")
  status          String    @default("")
  seoScore        Int       @default(0)
  metaTitle       String    @default("")
  metaDescription String    @default("")
  focusKeyword    String    @default("")
  imageUrl        String    @default("")
  imageAlt        String    @default("")
  issues          String?
  issueCount      Int       @default(0)
  contentHash     String?
  sourceUpdatedAt DateTime?
  lastAnalyzedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([shop, resourceType, resourceId])
  @@index([shop, resourceType, seoScore])
  @@index([shop, resourceType, issueCount])
  @@index([shop, sourceUpdatedAt])
}

model SeoScanJob {
  id             String    @id @default(cuid())
  shop           String
  status         String    @default("queued")
  trigger        String    @default("manual")
  phase          String    @default("Queued")
  progress       Int       @default(0)
  totalPosts     Int       @default(0)
  processedPosts Int       @default(0)
  analyzedPosts  Int       @default(0)
  averageScore   Int?
  error          String?
  requestedAt    DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  heartbeatAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([shop, requestedAt])
  @@index([status, requestedAt])
}

// Analytics: tracking widget events
model WidgetEvent {
  id        String   @id @default(cuid())
  shop      String
  articleId String
  productId String
  blockId   String   @default("default")
  eventType String
  sessionId String?
  referrer  String?
  eventKey  String?  @unique
  createdAt DateTime @default(now())

  @@index([shop, createdAt])
  @@index([articleId])
  @@index([articleId, blockId])
  @@index([productId])
}

model AnalyticsDaily {
  id          String   @id @default(cuid())
  shop        String
  date        DateTime
  articleId   String
  productId   String
  source      String   @default("Direct")
  impressions Int      @default(0)
  clicks      Int      @default(0)
  addToCarts  Int      @default(0)
  purchases   Int      @default(0)
  sessions    Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([shop, date, articleId, productId, source])
  @@index([shop, date])
  @@index([shop, articleId, date])
  @@index([shop, productId, date])
}

model AnalyticsDailySession {
  id         String   @id @default(cuid())
  shop       String
  date       DateTime
  articleId  String
  productId  String
  source     String
  sessionKey String
  createdAt  DateTime @default(now())

  @@unique([shop, date, articleId, productId, source, sessionKey])
  @@index([shop, date])
}

model SearchConsoleConnection {
  id                      String    @id @default(cuid())
  shop                    String    @unique
  accessTokenEncrypted    String
  refreshTokenEncrypted   String?
  tokenExpiresAt          DateTime?
  scope                   String?
  selectedSiteUrl         String?
  selectedPermissionLevel String?
  availableSites          Json?
  lastSyncedAt            DateTime?
  lastSyncError           String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model SearchConsoleOAuthState {
  id        String   @id @default(cuid())
  shop      String   @unique
  stateHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model SearchConsoleMetric {
  id          String   @id @default(cuid())
  shop        String
  siteUrl     String
  pageUrl     String
  query       String   @default("")
  windowDays  Int
  period      String   @default("current")
  clicks      Float    @default(0)
  impressions Float    @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)
  syncedAt    DateTime @default(now())

  @@unique([shop, siteUrl, pageUrl, query, windowDays, period])
  @@index([shop, siteUrl, windowDays, period])
  @@index([shop, pageUrl])
}

model InternalLinkAnalysis {
  id         String   @id @default(cuid())
  shop       String   @unique
  report     Json
  analyzedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model InternalLinkChange {
  id           String    @id @default(cuid())
  batchId      String
  shop         String
  articleId    String
  articleTitle String
  beforeBody   String
  afterBody    String
  suggestions  Json
  status       String    @default("applied")
  appliedAt    DateTime  @default(now())
  undoneAt     DateTime?

  @@index([shop, appliedAt])
  @@index([shop, batchId])
}

model ContentBrief {
  id                 String   @id @default(cuid())
  shop               String
  title              String
  seedKeyword        String   @default("")
  sourceArticleId    String   @default("")
  sourceArticleTitle String   @default("")
  status             String   @default("ready")
  brief              Json
  draft              Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([shop, updatedAt])
}

model ContentDecayAnalysis {
  id         String   @id @default(cuid())
  shop       String   @unique
  report     Json
  analyzedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model StorefrontPerformanceScan {
  id           String    @id @default(cuid())
  shop         String
  pageType     String
  pageTitle    String
  pageUrl      String
  seoScore     Int       @default(0)
  mobileScore  Int       @default(0)
  desktopScore Int       @default(0)
  report       Json?
  status       String    @default("completed")
  error        String?
  scannedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([shop, pageType])
  @@index([shop, scannedAt])
}

model SeoBulkChange {
  id                    String    @id @default(cuid())
  batchId               String
  shop                  String
  articleId             String
  articleTitle          String
  beforeMetaTitle       String    @default("")
  beforeMetaDescription String    @default("")
  afterMetaTitle        String    @default("")
  afterMetaDescription  String    @default("")
  imageUrl              String    @default("")
  beforeImageAlt        String    @default("")
  afterImageAlt         String    @default("")
  status                String    @default("applied")
  appliedAt             DateTime  @default(now())
  undoneAt              DateTime?

  @@index([shop, appliedAt])
  @@index([shop, batchId])
}

model ImageSeoChange {
  id           String    @id @default(cuid())
  batchId      String    @unique
  shop         String
  changes      Json
  articleCount Int
  imageCount   Int
  status       String    @default("applied")
  appliedAt    DateTime  @default(now())
  undoneAt     DateTime?

  @@index([shop, appliedAt])
}

model AiUsage {
  id          String   @id @default(cuid())
  shop        String
  periodStart DateTime
  requests    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shop, periodStart])
  @@index([periodStart])
}
