{% comment %}
  Advanced visual breadcrumbs for articles and storefront pages.
  Settings can use global app config or block-level overrides.
{% endcomment %}
<script src="{{ 'sbs-content-nav.js' | asset_url }}" defer="defer"></script>

{% liquid
  assign sbs_app_url = '/apps/shoppable-blog-seo'
  assign sbs_current_title = page_title
  assign sbs_current_url = canonical_url
  assign sbs_parent_title = ''
  assign sbs_parent_url = ''

  if article
    assign sbs_current_title = article.title
    if article.url
      assign sbs_current_url = article.url | prepend: shop.url
    endif
    if blog
      assign sbs_parent_title = blog.title
      assign sbs_parent_url = blog.url
    endif
  elsif product
    assign sbs_current_title = product.title
    if product.url
      assign sbs_current_url = product.url | prepend: shop.url
    endif
    if collection
      assign sbs_parent_title = collection.title
      assign sbs_parent_url = collection.url
    endif
  elsif collection
    assign sbs_current_title = collection.title
    if collection.url
      assign sbs_current_url = collection.url | prepend: shop.url
    endif
  elsif page
    assign sbs_current_title = page.title
    if page.url
      assign sbs_current_url = page.url | prepend: shop.url
    endif
  elsif blog
    assign sbs_current_title = blog.title
    if blog.url
      assign sbs_current_url = blog.url | prepend: shop.url
    endif
  endif
%}

{% if sbs_current_title != blank %}
  <nav
    class="bp-content-nav bp-breadcrumbs"
    hidden
    data-bp-content-nav="breadcrumbs"
    data-shop="{{ shop.permanent_domain }}"
    data-app-url="{{ sbs_app_url }}"
    data-enabled="{{ block.settings.enabled }}"
    data-style="{{ block.settings.style }}"
    data-show-home="{{ block.settings.show_home }}"
    data-home-label="{{ block.settings.home_label | escape }}"
    data-home-url="{{ routes.root_url }}"
    data-show-blog="{{ block.settings.show_blog }}"
    data-current-clickable="{{ block.settings.current_clickable }}"
    data-separator="{{ block.settings.separator | escape }}"
    data-blog-title="{{ sbs_parent_title | escape }}"
    data-blog-url="{{ sbs_parent_url }}"
    data-article-title="{{ sbs_current_title | escape }}"
    data-article-url="{{ sbs_current_url }}"
  ></nav>
{% endif %}

{% schema %}
{
  "name": "Advanced Breadcrumbs",
  "target": "section",
  "stylesheet": "sbs-content-nav.css",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "select",
      "id": "style",
      "label": "Style",
      "default": "global",
      "options": [
        { "value": "global", "label": "Use app settings" },
        { "value": "minimal", "label": "Minimal" },
        { "value": "slash", "label": "Slash" },
        { "value": "pills", "label": "Pills" },
        { "value": "boxed", "label": "Boxed" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_home",
      "label": "Show home link",
      "default": true
    },
    {
      "type": "text",
      "id": "home_label",
      "label": "Home label",
      "default": "Home"
    },
    {
      "type": "checkbox",
      "id": "show_blog",
      "label": "Show blog link",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "current_clickable",
      "label": "Make current article clickable",
      "default": false
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator",
      "default": "/"
    }
  ]
}
{% endschema %}
