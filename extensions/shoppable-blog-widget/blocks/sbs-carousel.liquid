{% comment %}
  theme-check-disable AssetSizeAppBlockJavaScript
  BP Shoppable Blog Widget — Product Carousel Block
  Displays embedded products as a responsive carousel on blog articles.
{% endcomment %}
<script src="{{ 'sbs-widget.js' | asset_url }}" defer="defer"></script>

{% liquid
  assign sbs_app_url = '/apps/shoppable-blog-seo'
  assign sbs_article_id = ''
  if article
    assign article_id_string = article.id | append: ''
    if article_id_string contains 'gid://'
      assign sbs_article_id = article_id_string
    else
      assign sbs_article_id = article_id_string | prepend: 'gid://shopify/Article/'
    endif
  endif
%}

<div
  class="bp-widget bp-carousel"
  data-article-id="{{ sbs_article_id }}"
  data-shop="{{ shop.permanent_domain }}"
  data-app-url="{{ sbs_app_url }}"
  data-style="carousel"
  id="bp-widget-{{ block.id }}"
>
  <div class="bp-carousel__wrapper">
    <button class="bp-carousel__nav bp-carousel__prev" aria-label="Previous">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div class="bp-carousel__track">
      <!-- Products loaded dynamically via JS -->
      <div class="bp-widget__loading">
        <div class="bp-widget__spinner"></div>
        <p>Loading products...</p>
      </div>
    </div>

    <button class="bp-carousel__nav bp-carousel__next" aria-label="Next">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>

  <div class="bp-carousel__dots"></div>
</div>

{% schema %}
{
  "name": "Product Carousel",
  "target": "section",
  "stylesheet": "sbs-widget.css",
  "settings": [
    {
      "type": "paragraph",
      "content": "Product data is loaded automatically through the app proxy."
    }
  ]
}
{% endschema %}
