# Shopify app
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://shopable-blog.bluepeaks.top
SCOPES=read_content,read_files,read_inventory,read_products,read_themes,write_app_proxy,write_content,write_files,write_pixels,read_customer_events

# PostgreSQL
DATABASE_URL=

# Google Search Console OAuth
GOOGLE_SEARCH_CONSOLE_CLIENT_ID=
GOOGLE_SEARCH_CONSOLE_CLIENT_SECRET=
GOOGLE_SEARCH_CONSOLE_REDIRECT_URI=https://shopable-blog.bluepeaks.top/app/seo/google/callback

# Generate a strong independent secret, for example: openssl rand -base64 32
# Never change this after users connect, or their stored Google tokens cannot be decrypted.
GOOGLE_TOKEN_ENCRYPTION_KEY=

# Raw tracking retention (daily aggregates are retained). Allowed range: 30-365 days.
RAW_EVENT_RETENTION_DAYS=90

# Optional independent secret for the localhost SEO worker. Falls back to SHOPIFY_API_SECRET.
SEO_WORKER_SECRET=
# Optional override when the Remix data endpoint is not available at the default localhost URL.
SEO_WORKER_URL=

# Optional 9Router integration for Edit Blog writing assistance and Bulk SEO suggestions.
# When 9Router runs on the same server: http://127.0.0.1:20128/v1
NINE_ROUTER_BASE_URL=
NINE_ROUTER_API_KEY=
NINE_ROUTER_MODEL=
# Reasoning models such as GPT-5/Codex default to low. Allowed: none, low, medium, high, xhigh.
NINE_ROUTER_REASONING_EFFORT=low
# Per-article timeout in milliseconds (1000-60000). Defaults to 20000.
NINE_ROUTER_TIMEOUT_MS=20000
